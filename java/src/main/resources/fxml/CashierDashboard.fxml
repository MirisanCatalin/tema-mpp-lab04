<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.ObservableList?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>
            <Label fx:id="welcomeLabel" text="Welcome, Cashier" font="$FONT_SIZE_LARGE">
                <font>
                    <Font size="20.0"/>
                </font>
            </Label>
            <Label text="Available Matches" font="$FONT_SIZE_MEDIUM">
                <font>
                    <Font size="16.0"/>
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- Matches Table -->
            <TableView fx:id="matchesTable" prefHeight="200">
                <columns>
                    <TableColumn text="ID" prefWidth="40"/>
                    <TableColumn text="Match Name" prefWidth="200"/>
                    <TableColumn text="Price (RON)" prefWidth="100"/>
                    <TableColumn text="Available Seats" prefWidth="120"/>
                    <TableColumn text="Total Seats" prefWidth="100"/>
                </columns>
            </TableView>

            <!-- Sell Ticket Section -->
            <Label text="Sell Ticket" font="$FONT_SIZE_MEDIUM">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="customerNameField" promptText="Customer Name" prefWidth="150"/>
                <TextField fx:id="customerAddressField" promptText="Customer Address" prefWidth="200"/>
                <TextField fx:id="matchIdField" promptText="Match ID" prefWidth="80"/>
                <TextField fx:id="seatsField" promptText="Seats" prefWidth="60"/>
                <Button fx:id="sellButton" text="Sell Ticket" onAction="#handleSellTicket"/>
            </HBox>

            <!-- Search Section -->
            <Label text="Search Tickets" font="$FONT_SIZE_MEDIUM">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchNameField" promptText="Customer Name" prefWidth="150"/>
                <TextField fx:id="searchAddressField" promptText="Address" prefWidth="200"/>
                <Button fx:id="searchButton" text="Search" onAction="#handleSearch"/>
            </HBox>

            <!-- Tickets Table -->
            <Label text="Tickets" font="$FONT_SIZE_MEDIUM">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>

            <TableView fx:id="ticketsTable" prefHeight="150">
                <columns>
                    <TableColumn text="Ticket ID" prefWidth="80"/>
                    <TableColumn text="Customer" prefWidth="150"/>
                    <TableColumn text="Match" prefWidth="150"/>
                    <TableColumn text="Seats" prefWidth="80"/>
                </columns>
            </TableView>

            <!-- Modify Ticket Section -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="ticketIdField" promptText="Ticket ID" prefWidth="100"/>
                <TextField fx:id="newSeatsField" promptText="New Seats" prefWidth="80"/>
                <Button fx:id="modifyButton" text="Modify Seats" onAction="#handleModify"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="20" bottom="20" left="20"/>
            </padding>
            <Label fx:id="statusLabel" text=""/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" cancelButton="true"/>
        </HBox>
    </bottom>
</BorderPane>
